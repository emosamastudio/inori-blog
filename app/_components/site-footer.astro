---
/**
 * Inori Blog — minimal footer.
 *
 * A quiet sign-off: name, a few links, copyright.
 */
import {
  DEFAULT_LOCALE,
  isLandingLocale,
  localizedHref,
} from '../i18n';

const rawLocale = Astro.props.locale ?? DEFAULT_LOCALE;
const locale = isLandingLocale(rawLocale) ? rawLocale : DEFAULT_LOCALE;
const href = (path: string) => localizedHref(path, locale);
const REPO = 'https://github.com/emosamastudio/inori-blog';
const year = new Date().getFullYear();
---

<footer class='sub-footer' data-od-id='sub-footer'>
  <div class='container sub-footer-inner'>
    <div class='sub-footer-grid'>
      <div class='sub-footer-brand'>
        <a href={href('/')} class='brand'>
          <span class='brand-name'>Inori</span>
          <span class='brand-mark-jp'>祈</span>
        </a>
        <p>一个安静的思考空间，由代码写就。</p>
      </div>
      <div class='sub-footer-col'>
        <h5>链接</h5>
        <ul>
          <li><a href={href('/blog/')}>博客</a></li>
          <li><a href={href('/about/')}>关于</a></li>
          <li><a href='/blog/rss.xml'>RSS</a></li>
          <li><a href={REPO} target='_blank' rel='noopener'>GitHub</a></li>
        </ul>
      </div>
    </div>
    <div class='sub-footer-bottom'>
      <span>&copy; {year} Inori</span>
    </div>
  </div>
</footer>
