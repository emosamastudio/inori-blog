---
/**
 * Localized blog index — `/{locale}/blog/`
 */
import CspMeta from '../../../_components/csp-meta.astro';
import { getCollection } from 'astro:content';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import GoogleAnalytics from '../../../_components/google-analytics.astro';
import HeaderEnhancer from '../../../_components/header-enhancer.astro';
import { Header } from '../../../_components/header';
import SeoHead from '../../../_components/seo-head.astro';
import SiteFooter from '../../../_components/site-footer.astro';
import Topbar from '../../../_components/topbar.astro';
import {
  LANDING_LOCALES,
  DEFAULT_LOCALE,
  getLocaleDefinition,
  localePath,
  alternateLinksForPath,
  type LandingLocaleCode,
} from '../../../i18n';
import {
  explicitLocalizedString,
  localizeBlogPostText,
} from '../../../content-i18n';
import '../../../globals.css';
import '../../../sub-pages.css';

export async function getStaticPaths() {
  return LANDING_LOCALES
    .filter((l) => l.code !== DEFAULT_LOCALE)
    .map((l) => ({ params: { locale: l.code } }));
}

const locale = Astro.params.locale as LandingLocaleCode;
const localeDef = getLocaleDefinition(locale);

// Localized post field helper
const localizedPostField = (post: (typeof posts)[number], field: 'title' | 'summary' | 'category') => {
  const postI18n = (post.data as any).i18n?.[locale];
  const fallback = localizeBlogPostText({
    id: post.id, title: post.data.title, summary: post.data.summary, category: post.data.category, locale,
  });
  return explicitLocalizedString(postI18n?.[field], locale) ?? fallback[field];
};

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featuredPost = posts[0];
const cardPosts = posts.slice(1);

const headerHtml = renderToStaticMarkup(
  createElement(Header, { brandHref: '/', active: 'blog', locale }),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString(localeDef.htmlLang, { year: 'numeric', month: 'long', day: 'numeric' });
const categoryValue = (c: string) => c.toLowerCase().replace(/\s+/g, '-');

const canonical = new URL(localePath(locale, '/blog/'), Astro.site).toString();
const alternateLinks = alternateLinksForPath('/blog/').map((entry) => ({
  ...entry,
  href: new URL(entry.hrefPath, Astro.site).toString(),
}));

const categoryChips = [
  { label: 'All', value: 'all' },
  { label: 'Product', value: 'product' },
  { label: 'Guides', value: 'guides' },
  { label: 'Use cases', value: 'use-cases' },
  { label: 'Community', value: 'community' },
];
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <CspMeta />
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <link rel='canonical' href={canonical} />
    {alternateLinks.map((entry) => (
      <link rel='alternate' hreflang={entry.hreflang} href={entry.href} />
    ))}
    <SeoHead kind='website' title={`Blog — Inori (${localeDef.label})`} description='Thoughts on code, design, and the quiet spaces between them.' pathname={Astro.url.pathname} />
    <GoogleAnalytics />
  </head>
  <body>
    <div class='shell'>
      <div class='site-chrome' data-chrome-headroom>
        <Topbar locale={locale} />
        <Fragment set:html={headerHtml} />
      </div>

      <main class='blog-shell'>
        <section class='blog-masthead'>
          <div class='container'>
            <h1 class='blog-title'>Writing</h1>
            <p class='blog-sub'>Thoughts on code, design, and the quiet spaces between them.</p>
          </div>
        </section>

        {featuredPost && (
          <section class='blog-feature' data-featured-post data-category={categoryValue(featuredPost.data.category)}>
            <div class='container'>
              <a class='blog-feature-card' href={`/${locale}/blog/${featuredPost.id}/`}>
                <span class='media-panel media-panel-large'>
                  <span class='media-kicker'>{localizedPostField(featuredPost, 'category')}</span>
                  <span class='media-title'>{localizedPostField(featuredPost, 'title')}</span>
                  <span class='media-grid' />
                  <span class='media-orbit' />
                </span>
                <span class='blog-feature-copy'>
                  <span class='blog-card-cat'>{localizedPostField(featuredPost, 'category')}</span>
                  <h2 class='blog-feature-title'>{localizedPostField(featuredPost, 'title')}</h2>
                  <p class='blog-feature-summary'>{localizedPostField(featuredPost, 'summary')}</p>
                  <span class='blog-feature-meta'>
                    <span>{fmtDate(featuredPost.data.date)}</span>
                    <span>·</span>
                    <span>{featuredPost.data.readingTime} min read</span>
                  </span>
                </span>
              </a>
            </div>
          </section>
        )}

        <section class='blog-categories'>
          <div class='container'>
            <div class='blog-category-strip'>
              {categoryChips.map((cat, i) => (
                <a class:list={['blog-chip', i === 0 && 'is-active']}
                  href={cat.value === 'all' ? `/${locale}/blog/` : `/${locale}/blog/?category=${cat.value}`}
                  data-category-filter={cat.value}>{cat.label}</a>
              ))}
            </div>
          </div>
        </section>

        <section class='blog-list'>
          <div class='container'>
            <ol class='blog-grid'>
              {cardPosts.map((post) => (
                <li class='blog-card' data-blog-item data-category={categoryValue(post.data.category)}>
                  <a class='blog-card-link' href={`/${locale}/blog/${post.id}/`}>
                    <span class='media-panel'>
                      <span class='media-kicker'>{localizedPostField(post, 'category')}</span>
                      <span class='media-title'>{localizedPostField(post, 'title')}</span>
                      <span class='media-grid' />
                      <span class='media-orbit' />
                    </span>
                    <span class='blog-card-body'>
                      <span class='blog-card-cat'>{localizedPostField(post, 'category')}</span>
                      <h2 class='blog-card-title'>{localizedPostField(post, 'title')}</h2>
                      <p class='blog-card-summary'>{localizedPostField(post, 'summary')}</p>
                      <span class='blog-card-foot'>
                        <span class='blog-card-date'>{fmtDate(post.data.date)}</span>
                        <span class='blog-card-rt'>{post.data.readingTime} min</span>
                        <span class='blog-card-cta'>Read</span>
                      </span>
                    </span>
                  </a>
                </li>
              ))}
            </ol>
            <p class='blog-empty is-filter-empty' data-blog-empty hidden>No posts in this category yet.</p>
          </div>
        </section>
      </main>
      <SiteFooter />
    </div>

    <script is:inline>
      (() => {
        const normalize = (v) => (v || 'all').toLowerCase();
        const params = new URLSearchParams(window.location.search);
        const active = normalize(params.get('category'));
        document.addEventListener('click', (e) => {
          const chip = e.target.closest('[data-category-filter]');
          if (!chip) return;
          e.preventDefault();
          const val = chip.getAttribute('data-category-filter');
          const url = new URL(window.location);
          if (val === 'all') url.searchParams.delete('category');
          else url.searchParams.set('category', val);
          window.history.pushState({}, '', url);
          const items = document.querySelectorAll('[data-blog-item]');
          let count = 0;
          for (const item of items) {
            const match = val === 'all' || item.getAttribute('data-category') === val;
            item.hidden = !match;
            if (match) count++;
          }
          for (const f of document.querySelectorAll('[data-category-filter]'))
            f.classList.toggle('is-active', f.getAttribute('data-category-filter') === val);
          const empty = document.querySelector('[data-blog-empty]');
          if (empty) empty.hidden = count !== 0;
        });
        (function apply(val) {
          const items = document.querySelectorAll('[data-blog-item]');
          let count = 0;
          for (const item of items) {
            const match = val === 'all' || item.getAttribute('data-category') === val;
            item.hidden = !match;
            if (match) count++;
          }
          for (const f of document.querySelectorAll('[data-category-filter]'))
            f.classList.toggle('is-active', f.getAttribute('data-category-filter') === val);
          const empty = document.querySelector('[data-blog-empty]');
          if (empty) empty.hidden = count !== 0;
        })(active);
        window.addEventListener('popstate', () => {
          const p = new URLSearchParams(window.location.search);
          const items = document.querySelectorAll('[data-blog-item]');
          const val = normalize(p.get('category'));
          let count = 0;
          for (const item of items) {
            const match = val === 'all' || item.getAttribute('data-category') === val;
            item.hidden = !match;
            if (match) count++;
          }
          for (const f of document.querySelectorAll('[data-category-filter]'))
            f.classList.toggle('is-active', f.getAttribute('data-category-filter') === val);
          const empty = document.querySelector('[data-blog-empty]');
          if (empty) empty.hidden = count !== 0;
        });
      })();
    </script>
    <HeaderEnhancer />
  </body>
</html>
