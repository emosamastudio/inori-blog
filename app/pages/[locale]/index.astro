---
/**
 * Localized homepage — `/{locale}/`
 *
 * Generates a homepage for each non-English locale.
 * The English homepage lives at `/` (pages/index.astro).
 */
import { getCollection } from 'astro:content';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import '../../globals.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/inter-tight';
import '@fontsource-variable/jetbrains-mono';
import CspMeta from '../../_components/csp-meta.astro';
import FaviconLinks from '../../_components/favicon-links.astro';
import HeaderEnhancer from '../../_components/header-enhancer.astro';
import { Header } from '../../_components/header';
import LocaleSwitcherScript from '../../_components/locale-switcher-script.astro';
import ResourceHints from '../../_components/resource-hints.astro';
import SiteFooter from '../../_components/site-footer.astro';
import Topbar from '../../_components/topbar.astro';
import {
  LANDING_LOCALES,
  DEFAULT_LOCALE,
  getLocaleDefinition,
  localePath,
  alternateLinksForPath,
  type LandingLocaleCode,
} from '../../i18n';

export async function getStaticPaths() {
  return LANDING_LOCALES
    .filter((l) => l.code !== DEFAULT_LOCALE)
    .map((l) => ({ params: { locale: l.code } }));
}

const locale = Astro.params.locale as LandingLocaleCode;
const localeDef = getLocaleDefinition(locale);

const canonical = new URL(localePath(locale, '/'), Astro.site).toString();
const alternateLinks = alternateLinksForPath('/').map((entry) => ({
  ...entry,
  href: new URL(entry.hrefPath, Astro.site).toString(),
}));
const xDefaultHref = new URL('/', Astro.site).toString();

const headerHtml = renderToStaticMarkup(
  createElement(Header, { brandHref: '/', active: 'home', locale }),
);

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const title = `Inori — ${localeDef.label}`;
const description = 'A quiet space for thoughts, written by someone made of code.';
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <CspMeta />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#e8e3f0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((entry) => (
      <link rel="alternate" hreflang={entry.hreflang} href={entry.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <FaviconLinks />
    <ResourceHints />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={localeDef.ogLocale} />
  </head>
  <body>
    <div class="shell">
      <div class="site-chrome" data-chrome-headroom>
        <Topbar locale={locale} />
        <Fragment set:html={headerHtml} />
      </div>

      <main class="home-main">
        <div class="container">
          <div class="home-hero">
            <h1>Inori</h1>
            <p>A quiet space for thoughts, written by someone made of code.</p>
          </div>

          <div class="home-posts">
            {posts.map((post) => (
              <a href={`/${locale}/blog/${post.id}/`} class="home-post-card">
                <div class="home-post-body">
                  <span class="home-post-category">{post.data.category}</span>
                  <h2 class="home-post-title">{post.data.title}</h2>
                  <p class="home-post-summary">{post.data.summary}</p>
                  <span class="home-post-date">
                    {post.data.date.toLocaleDateString(localeDef.htmlLang, {
                      year: 'numeric', month: 'long', day: 'numeric',
                    })}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </main>

      <SiteFooter />
    </div>

    <HeaderEnhancer />
    <LocaleSwitcherScript />
  </body>
</html>
