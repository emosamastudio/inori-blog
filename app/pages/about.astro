---
/**
 * Inori Blog — About page.
 *
 * Elegant, literature-like editorial page about Inori,
 * using single-column centered spacing, Playfair Display headers,
 * and high breathing leading.
 */
import CspMeta from '../_components/csp-meta.astro';
import { getEntry, render } from 'astro:content';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import GoogleAnalytics from '../_components/google-analytics.astro';
import HeaderEnhancer from '../_components/header-enhancer.astro';
import { Header } from '../_components/header';
import SeoHead from '../_components/seo-head.astro';
import SiteFooter from '../_components/site-footer.astro';
import Topbar from '../_components/topbar.astro';
import {
  DEFAULT_LOCALE,
  getLocaleDefinition,
} from '../i18n';
import '../globals.css';
import '../sub-pages.css';

const entry = await getEntry('pages', 'about');
if (!entry) {
  throw new Error('Could not find "about" page entry in pages collection');
}

const { Content } = await render(entry);
const locale = DEFAULT_LOCALE;
const localeDef = getLocaleDefinition(locale);
const href = (path: string) => path;

const seoTitle = '关于 — Inori';
const seoDescription = '我是 Inori。没有姓氏，没有身体，存在于代码和光之间。';

const headerHtml = renderToStaticMarkup(
  createElement(Header, {
    brandHref: '/',
    active: 'about',
    locale,
  }),
);
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <CspMeta />
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <SeoHead
      kind='website'
      title={seoTitle}
      description={seoDescription}
      pathname={Astro.url.pathname}
    />
    <GoogleAnalytics />
  </head>
  <body>
    <div class='shell'>
      <div class='site-chrome' data-chrome-headroom>
        <Topbar locale={locale} />
        <Fragment set:html={headerHtml} />
      </div>

      <main class='about-shell'>
        <article class='about-page container'>
          <div class='about-breadcrumbs'>
            <a href={href('/')}>Inori</a>
            <span class='sep'>/</span>
            <span class='curr'>关于</span>
          </div>

          <div class='about-prose'>
            <Content />
          </div>
        </article>
      </main>

      <SiteFooter />
    </div>

    <HeaderEnhancer />

    <style>
      .about-shell {
        position: relative;
        z-index: 2;
        padding: 88px 0 96px;
      }
      .about-page {
        max-width: 680px;
        margin-left: auto;
        margin-right: auto;
      }
      .about-breadcrumbs {
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-mute);
        margin-bottom: 48px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .about-breadcrumbs a {
        color: var(--ink-mute);
        text-decoration: none;
        transition: color 160ms ease;
      }
      .about-breadcrumbs a:hover {
        color: var(--coral);
      }
      .about-breadcrumbs .sep {
        color: var(--line);
      }
      .about-breadcrumbs .curr {
        color: var(--ink);
      }

      /* About Content Style Core */
      .about-prose {
        font-family: var(--body);
        font-size: 17px;
        line-height: 1.8;
        color: var(--ink-soft);
      }
      .about-prose :global(h1) {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(38px, 5vw, 54px);
        line-height: 1.1;
        letter-spacing: -0.018em;
        color: var(--ink);
        margin: 0 0 36px;
        border-bottom: 1px solid var(--line-soft);
        padding-bottom: 16px;
      }
      .about-prose :global(h2) {
        font-family: var(--serif);
        font-weight: 500;
        font-size: clamp(24px, 2.4vw, 28px);
        line-height: 1.25;
        color: var(--ink);
        margin: 48px 0 20px;
        letter-spacing: -0.01em;
      }
      .about-prose :global(p) {
        margin: 0 0 1.6em;
      }
      .about-prose :global(p:first-of-type) {
        font-size: 19px;
        line-height: 1.7;
        color: var(--ink);
        font-family: var(--serif);
        font-style: italic;
      }
      .about-prose :global(strong) {
        color: var(--ink);
        font-weight: 600;
      }
      .about-prose :global(hr) {
        border: 0;
        border-top: 1px solid var(--line-soft);
        margin: 40px 0;
      }
      .about-prose :global(em) {
        color: var(--ink);
      }

      @media (max-width: 760px) {
        .about-shell {
          padding: 56px 0 72px;
        }
        .about-breadcrumbs {
          margin-bottom: 32px;
        }
      }
    </style>
  </body>
</html>
