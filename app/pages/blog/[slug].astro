---
/**
 * Inori Blog — article page.
 *
 * Narrow editorial body with serif title, italic excerpt,
 * refined typography, and a quiet footer.
 */
import CspMeta from '../../_components/csp-meta.astro';
import { getCollection, render } from 'astro:content';
import { createElement } from 'react';
import { renderToStaticMarkup } from 'react-dom/server';
import GoogleAnalytics from '../../_components/google-analytics.astro';
import HeaderEnhancer from '../../_components/header-enhancer.astro';
import { Header } from '../../_components/header';
import SeoHead from '../../_components/seo-head.astro';
import SiteFooter from '../../_components/site-footer.astro';
import Topbar from '../../_components/topbar.astro';
import {
  getLocaleDefinition,
  localeFromPath,
  localizedHref,
  type LandingLocaleCode,
} from '../../i18n';
import {
  explicitLocalizedString,
  localizeBlogPostText,
} from '../../content-i18n';
import '../../globals.css';
import '../../sub-pages.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const locale = localeFromPath(Astro.url.pathname);
const localeDef = getLocaleDefinition(locale);
const href = (path: string) => localizedHref(path, locale);

// Localized content — three-tier fallback:
//   1. i18n.<locale>.<field> in frontmatter (hand-translated)
//   2. localizeBlogPostText() auto-generated translation
//   3. Original English field
const localizedPostI18n = (post.data as typeof post.data & {
  i18n?: Record<string, Partial<Record<'title' | 'summary' | 'category' | 'bodyHtml', string>>>;
}).i18n?.[locale];
const fallbackPost = localizeBlogPostText({
  id: post.id, title: post.data.title, summary: post.data.summary, category: post.data.category, locale,
});
const localizedField = (field: 'title' | 'summary' | 'category') =>
  explicitLocalizedString(localizedPostI18n?.[field] as Parameters<typeof explicitLocalizedString>[0], locale)
  ?? fallbackPost[field];
const localizedBodyHtml = explicitLocalizedString(
  localizedPostI18n?.bodyHtml as Parameters<typeof explicitLocalizedString>[0], locale,
) ?? fallbackPost.bodyHtml;

const sourceUrl = `https://github.com/emosamastudio/inori-blog/blob/main/app/content/blog/${post.id}.md`;

const origin = Astro.site?.toString() ?? 'https://inori.blog/';
const postUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://inori.blog/').toString();

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inori', item: origin },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', origin).toString() },
    { '@type': 'ListItem', position: 3, name: localizedField('title'), item: postUrl },
  ],
};

const headerHtml = renderToStaticMarkup(
  createElement(Header, {
    brandHref: '/',
    active: 'blog',
    locale,
  }),
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString(localeDef.htmlLang, {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<!doctype html>
<html lang={localeDef.htmlLang} dir={localeDef.dir}>
  <head>
    <CspMeta />
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <SeoHead
      kind='article'
      title={localizedField('title')}
      description={localizedField('summary')}
      pathname={Astro.url.pathname}
      datePublished={post.data.date}
      category={localizedField('category')}
    />
    <script is:inline type='application/ld+json' set:html={JSON.stringify(breadcrumbJsonLd)} />
    <GoogleAnalytics />
  </head>
  <body>
    <div class='shell'>
      <div class='site-chrome' data-chrome-headroom>
        <Topbar locale={locale} />
        <Fragment set:html={headerHtml} />
      </div>

      <main class='post-shell'>
      <article class='post'>
        <div class='container'>
          <a class='post-back' href={href('/blog/')}>← Back to writing</a>

          <h1 class='post-title'>{localizedField('title')}</h1>
          <p class='post-summary'>{localizedField('summary')}</p>

          <div class='post-meta'>
            <span>{fmtDate(post.data.date)}</span>
            <span>{post.data.readingTime} min read</span>
            <span>{localizedField('category')}</span>
          </div>

          <hr class='post-rule' />

          <div class='post-body'>
            {localizedBodyHtml ? (
              <Fragment set:html={localizedBodyHtml} />
            ) : (
              <Content />
            )}
          </div>

          <hr class='post-rule' />

          <div class='post-foot'>
            <a class='post-back' href={href('/blog/')}>← Back to writing</a>
            <a
              class='post-github'
              href={sourceUrl}
              target='_blank'
              rel='noreferrer noopener'
            >
              View source ↗
            </a>
          </div>
        </div>
      </article>
      </main>
      <SiteFooter />
    </div>

    <HeaderEnhancer />

    <style>
      .post-shell { position: relative; z-index: 2; }
      .post { padding: 88px 0 96px; }
      .post .container { max-width: 680px; }
      .post-back { display: inline-block; font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-mute); text-decoration: none; margin-bottom: 36px; transition: color 160ms ease; }
      .post-back:hover { color: var(--coral); }
      .post-title { font-family: var(--serif); font-weight: 500; font-size: clamp(38px, 5vw, 58px); line-height: 1.08; letter-spacing: -0.018em; color: var(--ink); margin: 18px 0 24px; }
      .post-summary { font-family: var(--serif); font-style: italic; font-weight: 400; font-size: clamp(18px, 1.8vw, 21px); line-height: 1.45; color: var(--ink-soft); max-width: 56ch; margin-bottom: 28px; }
      .post-meta { display: flex; flex-wrap: wrap; gap: 8px 10px; font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em; color: var(--ink-faint); margin-bottom: 32px; }
      .post-meta span + span::before { content: ''; display: inline-block; width: 14px; height: 1px; margin-right: 10px; vertical-align: middle; background: var(--line); }
      .post-rule { border: 0; border-top: 1px solid var(--line); margin: 0 0 40px; }
      .post-body { font-family: var(--body); font-size: 17px; line-height: 1.7; color: var(--ink-soft); }
      .post-body :global(p) { margin: 0 0 1.4em; }
      .post-body :global(h2) { font-family: var(--serif); font-weight: 500; font-size: clamp(26px, 2.6vw, 32px); line-height: 1.2; color: var(--ink); margin: 2.2em 0 0.8em; }
      .post-body :global(h3) { font-family: var(--sans); font-weight: 600; font-size: 18px; color: var(--ink); margin: 1.8em 0 0.6em; }
      .post-body :global(a) { color: var(--coral); text-decoration: underline; text-underline-offset: 3px; }
      .post-body :global(strong) { color: var(--ink); font-weight: 600; }
      .post-body :global(blockquote) { border-left: 2px solid var(--coral); padding-left: 18px; margin: 1.6em 0; font-family: var(--serif); font-style: italic; color: var(--ink-soft); }
      .post-body :global(code) { font-family: var(--mono); font-size: 0.9em; background: var(--paper-warm); padding: 2px 6px; border-radius: 3px; color: var(--ink); }
      .post-body :global(pre) { background: var(--bone); border: 1px solid var(--line-soft); padding: 20px 22px; border-radius: 4px; overflow-x: auto; margin: 1.4em 0; font-family: var(--mono); font-size: 13px; line-height: 1.55; }
      .post-body :global(pre.astro-code), .post-body :global(pre.shiki) { background-color: var(--bone) !important; color: var(--ink) !important; }
      .post-body :global(pre code) { background: transparent; padding: 0; font-size: inherit; }
      .post-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.4em 0; font-family: var(--body); font-size: 15px; }
      .post-body :global(th), .post-body :global(td) { border-bottom: 1px solid var(--line-soft); padding: 10px 12px; text-align: left; vertical-align: top; }
      .post-body :global(th) { font-family: var(--sans); font-weight: 600; color: var(--ink); border-bottom: 1px solid var(--line); }
      .post-body :global(hr) { border: 0; border-top: 1px solid var(--line-soft); margin: 2em 0; }
      .post-foot { display: flex; justify-content: space-between; align-items: center; gap: 16px; margin-top: 8px; }
      .post-foot .post-back { margin-bottom: 0; }
      .post-github { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-mute); text-decoration: none; transition: color 160ms ease; }
      .post-github:hover { color: var(--coral); }
      @media (max-width: 760px) { .post { padding: 56px 0 72px; } .post-foot { flex-direction: column; align-items: flex-start; } }
    </style>
  </body>
</html>
