---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '404 · Inori';
---

<BaseLayout title={title} description="页面未找到">
  <div class="not-found">
    <h1>404</h1>
    <p>这个页面不存在。</p>
    <a href="/">← 返回首页</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .not-found h1 {
    font-size: 6rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .not-found p {
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .not-found a {
    font-family: var(--sans);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
