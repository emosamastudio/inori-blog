---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((p) => ({ params: { slug: p.id.replace('.md', '') } }));
}

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post = posts.find((p) => p.id.replace('.md', '') === slug && !p.data.draft);

if (!post) return Astro.redirect('/404');

const { Content } = await post.render();
const title = `${post.data.title} · Inori`;
const description = post.data.summary;

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const index = allPosts.findIndex((p) => p.id.replace('.md', '') === slug);
const prev = index > 0 ? allPosts[index - 1] : null;
const next = index < allPosts.length - 1 ? allPosts[index + 1] : null;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={post.data.date.toISOString().slice(0, 10)}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span class="post-category">{post.data.category}</span>
        <span class="post-reading-time">{post.data.readingTime} min read</span>
      </div>
      <h1>{post.data.title}</h1>
      {post.data.summary && (
        <p class="post-subtitle">{post.data.summary}</p>
      )}
    </header>

    <div class="post-body">
      <Content />
    </div>

    <hr />

    <nav class="post-nav">
      {prev ? (
        <a href={`/blog/${prev.id.replace('.md', '')}`} class="post-nav-link">
          <span class="post-nav-label">← 上一篇</span>
          <span class="post-nav-title">{prev.data.title}</span>
        </a>
      ) : <div />}
      {next ? (
        <a href={`/blog/${next.id.replace('.md', '')}`} class="post-nav-link right">
          <span class="post-nav-label">下一篇 →</span>
          <span class="post-nav-title">{next.data.title}</span>
        </a>
      ) : <div />}
    </nav>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--muted);
    letter-spacing: 0.03em;
  }

  .post-category {
    display: inline-block;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .post-reading-time {
    font-family: var(--mono);
    font-size: 0.7rem;
  }

  .post-header h1 {
    font-size: 2.2rem;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .post-subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    line-height: 1.6;
    font-style: italic;
  }

  .post-body {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .post-body :global(p) {
    margin-bottom: 1.35em;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-body :global(ol),
  .post-body :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1.35em;
  }

  .post-body :global(li) {
    margin-bottom: 0.4em;
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .post-nav-link {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 48%;
  }

  .post-nav-link.right {
    text-align: right;
  }

  .post-nav-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-nav-title {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink);
    line-height: 1.4;
  }

  .post-nav-link:hover .post-nav-title {
    color: var(--accent);
  }
</style>
