{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"skipLibCheck": true,
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		]
	},
	"include": [
		".astro/types.d.ts",
		"src",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules"
	]
}